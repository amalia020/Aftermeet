# AfterMeet environment. Copy to .env.local and fill what you have.
# The app runs fully in demo/fixture mode when keys are absent.

# Force demo mode regardless of keys (true/false). Default: auto (demo if keys missing).
AFTERMEET_DEMO_MODE=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
CALA_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Persistence is optional; the MVP uses an in-memory store by default (ADR-004).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

MOLLIE_PAYMENT_LINK=
